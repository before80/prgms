&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;sudo tcpdump -i eth0 -n &lt;span style="color:#98c379"&gt;&amp;#39;udp port 53&amp;#39;&lt;/span&gt;
